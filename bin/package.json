{
	"name": "wp-upgrade-skills-builder",
	"version": "0.1.0",
	"private": false,
	"type": "module",
	"license": "GPL-3.0-or-later",
	"description": "Build scripts for generating WordPress upgrade Agent Skills.",
	"scripts": {
		"generate": "node make-release-notes.mjs",
		"validate": "node validate-skills.mjs",
		"format": "prettier --write . && prettier --write ../README.md ../AGENTS.md",
		"format:check": "prettier --check . && prettier --check ../README.md ../AGENTS.md"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"prettier": "@wordpress/prettier-config",
	"dependencies": {
		"fast-xml-parser": "^5.8.0"
	},
	"devDependencies": {
		"@wordpress/prettier-config": "^4.41.0",
		"prettier": "^3.8.1"
	}
}
